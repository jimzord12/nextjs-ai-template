{
  "$schema": "https://biomejs.dev/schemas/2.4.16/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "ignoreUnknown": false
  },
  "formatter": {
    "enabled": true,
    "formatWithErrors": false,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 80
  },
  "css": {
    "parser": {
      "tailwindDirectives": true
    }
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "complexity": {
        "noForEach": "error",
        "useLiteralKeys": "error"
      },
      "correctness": {
        "noUnusedVariables": "error",
        "useExhaustiveDependencies": "warn"
      },
      "style": {
        "noProcessEnv": "error",
        "noParameterProperties": "error",
        "noRestrictedImports": "off",
        "useConst": "error"
      }
    }
  },
  "overrides": [
    {
      "includes": ["src/env.ts"],
      "linter": {
        "rules": {
          "style": {
            "noProcessEnv": "off"
          }
        }
      }
    },
    {
      "includes": [
        "src/app/**",
        "src/components/**",
        "src/shared/**",
        "src/lib/**",
        "src/test/**"
      ],
      "linter": {
        "rules": {
          "style": {
            "noRestrictedImports": {
              "level": "error",
              "options": {
                "patterns": [
                  {
                    "group": ["@/features/*/**"],
                    "message": "Import feature modules through their public barrel exports, for example '@/features/foo'."
                  }
                ]
              }
            }
          }
        }
      }
    },
    {
      "includes": ["src/shared/**"],
      "linter": {
        "rules": {
          "style": {
            "noRestrictedImports": {
              "level": "error",
              "options": {
                "patterns": [
                  {
                    "group": ["@/features/**"],
                    "message": "The shared layer must stay feature-agnostic and cannot import from '@/features'."
                  }
                ]
              }
            }
          }
        }
      }
    },
    {
      "includes": [
        "src/components/**",
        "src/features/**",
        "src/shared/**",
        "src/lib/**",
        "src/test/**"
      ],
      "linter": {
        "rules": {
          "style": {
            "noRestrictedImports": {
              "level": "error",
              "options": {
                "patterns": [
                  {
                    "group": ["@/app/**"],
                    "message": "Route-local code under '@/app' must stay inside the App Router tree. Promote reusable code into shared public modules instead."
                  }
                ]
              }
            }
          }
        }
      }
    },
    {
      "includes": [".agents/**"],
      "formatter": {
        "enabled": false
      },
      "linter": {
        "rules": {
          "complexity": {
            "useOptionalChain": "off"
          },
          "correctness": {
            "noUnusedFunctionParameters": "off",
            "noUnusedImports": "off",
            "noUnusedVariables": "off"
          },
          "style": {
            "useTemplate": "off",
            "noProcessEnv": "off"
          },
          "suspicious": {
            "useIterableCallbackReturn": "off",
            "noAssignInExpressions": "off",
            "noControlCharactersInRegex": "off",
            "noShadowRestrictedNames": "off"
          }
        }
      },
      "assist": {
        "actions": {
          "source": {
            "organizeImports": "off"
          }
        }
      }
    }
  ],
  "javascript": {
    "formatter": {
      "quoteStyle": "double"
    }
  },
  "assist": {
    "enabled": true,
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    }
  }
}
