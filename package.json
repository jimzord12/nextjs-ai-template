{
  "name": "nextjs-ai-template",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "biome check .",
    "typecheck": "tsc --noEmit",
    "check": "pnpm lint && pnpm typecheck",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "qa:performance": "lhci autorun",
    "qa:a11y": "playwright test e2e/accessibility.spec.ts",
    "qa:cross-browser": "playwright test --project=chromium --project=firefox --project=webkit",
    "qa:security": "pnpm audit --audit-level high",
    "qa": "bash scripts/qa-report.sh",
    "prepare": "husky",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "doctor": "react-doctor",
    "fallow": "fallow",
    "fallow:audit": "fallow audit"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@tanstack/react-form": "^1.33.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.16.0",
    "next": "16.2.6",
    "next-intl": "^4.13.0",
    "next-themes": "^0.4.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "shadcn": "^4.8.2",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@biomejs/biome": "^2.4.16",
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.60.0",
    "@storybook/react": "^10.4.1",
    "@storybook/react-vite": "^10.4.1",
    "@tailwindcss/postcss": "4.3.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.2",
    "fallow": "^2.85.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.5",
    "react-doctor": "^0.2.15",
    "storybook": "^10.4.1",
    "tailwindcss": "4.3.0",
    "typescript": "5.9.3",
    "vitest": "^4.1.7"
  },
  "ignoreScripts": [
    "sharp",
    "unrs-resolver"
  ],
  "trustedDependencies": [
    "sharp",
    "unrs-resolver"
  ],
  "packageManager": "pnpm@11.5.0"
}
